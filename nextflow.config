// ============================================================
// RNASeq Soja – Nextflow Configuration
// ============================================================

nextflow.enable.dsl = 2

// ── Resolve o prefixo mamba em tempo de config (Groovy) ──────
// CONDA_PREFIX aponta para o env base (ex: /home/user/miniforge3)
// Os envs ficam em $CONDA_PREFIX/envs/<nome>
def _mambaRoot = System.getenv('CONDA_PREFIX')      ?:
                 System.getenv('MAMBA_ROOT_PREFIX') ?:
                 "${System.getProperty('user.home')}/miniforge3"

def ENV_TOOLS = "${_mambaRoot}/envs/rnaseq-tools"
def ENV_R     = "${_mambaRoot}/envs/r-analysis"

// Default parameters (overridden by params.yaml or CLI)
params {
    samplesheet     = "samplesheet.csv"
    genome_fasta    = null
    genome_gff3     = null
    genome_gtf      = null           // null = converter automaticamente do GFF3
    genome_index    = null           // null = construir índice automaticamente
    outdir          = "results"
    contrast        = "treatment_vs_control"
    control_group   = "control"
    treatment_group = "treatment"

    // Critérios DESeq2
    padj_cutoff     = 0.05
    lfc_cutoff      = 1.0

    // featureCounts
    strandedness    = 0              // 0=unstranded, 1=forward, 2=reverse (-1=auto)
    feature_type    = "exon"
    gene_attr       = "gene_id"

    // rMATS
    read_length     = 150
    rmats_type      = "paired"       // paired ou single

    // HISAT2
    hisat2_threads    = 16
    hisat2_max_intron = 500000

    // fastp
    min_length      = 36
    quality         = 20

    // Organism KEGG
    kegg_organism   = "gma"

    // Relatório
    report_title    = "RNASeq Insight – Glycine max"
    report_author   = "Eulalio Santos"
}

// ── Ativa mamba globalmente ───────────────────────────────────
conda {
    enabled  = true
    useMamba = true
}

// ── Perfis de execução ────────────────────────────────────────
profiles {

    local {
        process {
            executor = 'local'
            cpus     = 16
            memory   = '64 GB'
            time     = '12 h'
        }
    }

    slurm {
        process {
            executor       = 'slurm'
            queue          = 'normal'
            cpus           = 16
            memory         = '64 GB'
            time           = '24 h'
            errorStrategy  = 'retry'
            maxRetries     = 2
            clusterOptions = '--partition=normal'
        }
    }

    test {
        params {
            samplesheet     = "data/example/samplesheet_test.csv"
            genome_fasta    = "data/example/genome_test.fa"
            genome_gff3     = "data/example/annotation_test.gff3"
            outdir          = "results_test"
            read_length     = 75
        }
        process {
            executor = 'local'
            cpus     = 2
            memory   = '8 GB'
            time     = '2 h'
        }
    }
}

// ── Processos: paths absolutos dos envs mamba já instalados ───
// Nextflow usa o diretório existente diretamente, sem criar nada.
process {

    withName: 'FASTQC.*' {
        cpus     = 4
        memory   = '8 GB'
        maxForks = 6
        conda    = ENV_TOOLS
    }
    withName: 'MULTIQC.*' {
        cpus   = 2
        memory = '8 GB'
        conda  = ENV_TOOLS
    }
    withName: 'FASTP' {
        cpus     = 8
        memory   = '16 GB'
        maxForks = 4
        conda    = ENV_TOOLS
    }
    withName: 'GFFREAD' {
        cpus   = 2
        memory = '8 GB'
        conda  = ENV_TOOLS
    }
    withName: 'HISAT2_BUILD' {
        cpus   = 16
        memory = '64 GB'
        time   = '6 h'
        conda  = ENV_TOOLS
    }
    withName: 'HISAT2_ALIGN' {
        cpus     = 8
        memory   = '32 GB'
        maxForks = 4
        conda    = ENV_TOOLS
    }
    withName: 'SAMTOOLS.*' {
        cpus     = 8
        memory   = '16 GB'
        maxForks = 4
        conda    = ENV_TOOLS
    }
    withName: 'INFER_STRANDEDNESS' {
        cpus   = 2
        memory = '4 GB'
        conda  = ENV_TOOLS
    }
    withName: 'FEATURECOUNTS' {
        cpus   = 16
        memory = '32 GB'
        conda  = ENV_TOOLS
    }
    withName: 'RMATS' {
        cpus   = 16
        memory = '64 GB'
        time   = '24 h'
        conda  = ENV_TOOLS
    }
    withName: 'PARSE_COUNTS' {
        cpus   = 2
        memory = '8 GB'
        conda  = ENV_TOOLS
    }
    withName: 'PARSE_RMATS' {
        cpus   = 2
        memory = '8 GB'
        conda  = ENV_TOOLS
    }
    withName: 'DESEQ2' {
        cpus   = 8
        memory = '32 GB'
        conda  = ENV_R
    }
    withName: 'ENRICHMENT' {
        cpus   = 8
        memory = '32 GB'
        conda  = ENV_R
    }
    withName: 'WGCNA' {
        cpus   = 16
        memory = '64 GB'
        conda  = ENV_R
    }
    withName: 'INTEGRATION' {
        cpus   = 4
        memory = '16 GB'
        conda  = ENV_R
    }
    withName: 'QUARTO_REPORT' {
        cpus   = 4
        memory = '16 GB'
        conda  = ENV_R
    }
}

// ── Relatórios Nextflow ───────────────────────────────────────
report {
    enabled   = true
    file      = "${params.outdir}/nextflow_report.html"
    overwrite = true
}

trace {
    enabled   = true
    file      = "${params.outdir}/nextflow_trace.txt"
    overwrite = true
    fields    = 'task_id,name,status,exit,realtime,%cpu,peak_rss,peak_vmem'
}

timeline {
    enabled   = true
    file      = "${params.outdir}/nextflow_timeline.html"
    overwrite = true
}

dag {
    enabled   = true
    file      = "${params.outdir}/nextflow_dag.html"
    overwrite = true
}

// ── Manifest ─────────────────────────────────────────────────
manifest {
    name            = 'soja-rnaseq'
    author          = 'Eulalio Santos'
    description     = 'Pipeline completo de RNA-Seq para Glycine max'
    version         = '1.0.0'
    nextflowVersion = '>=24.04'
}
