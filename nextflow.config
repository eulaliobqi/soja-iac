// ============================================================
// RNASeq Soja – Nextflow Configuration
// ============================================================

nextflow.enable.dsl = 2

// Default parameters (overridden by params.yaml or CLI)
params {
    samplesheet     = "samplesheet.csv"
    genome_fasta    = null
    genome_gff3     = null
    genome_gtf      = null
    genome_index    = null
    outdir          = "results"
    contrast        = "treatment_vs_control"
    control_group   = "control"
    treatment_group = "treatment"

    padj_cutoff     = 0.05
    lfc_cutoff      = 1.0

    strandedness    = 0
    feature_type    = "exon"
    gene_attr       = "gene_id"

    read_length     = 150
    rmats_type      = "paired"

    hisat2_threads    = 16
    hisat2_max_intron = 500000
    min_align_rate    = 40

    min_length      = 36
    quality         = 20

    kegg_organism   = "gmx"  // Glycine max; "gma" é Granulicella mallensis (bactéria)
    go_annot        = null  // Caminho para annotation_info do Phytozome (opcional)

    report_title    = "RNASeq Insight – Glycine max"
    report_author   = "Eulalio Santos"
}

// ── Mamba: usa os ambientes já instalados (CONDA_PREFIX/envs/) ─
conda {
    enabled  = true
    useMamba = true
}

// ── Perfis de execução ────────────────────────────────────────
profiles {

    local {
        process {
            executor = 'local'
            cpus     = 16
            memory   = '64 GB'
            time     = '12 h'
        }
    }

    slurm {
        process {
            executor       = 'slurm'
            queue          = 'normal'
            cpus           = 16
            memory         = '64 GB'
            time           = '24 h'
            errorStrategy  = 'retry'
            maxRetries     = 2
            clusterOptions = '--partition=normal'
        }
    }

    test {
        params {
            samplesheet = "data/example/samplesheet_test.csv"
            genome_fasta = "data/example/genome_test.fa"
            genome_gff3  = "data/example/annotation_test.gff3"
            outdir       = "results_test"
            read_length  = 75
        }
        process {
            executor = 'local'
            cpus     = 2
            memory   = '8 GB'
            time     = '2 h'
        }
    }
}

// ── Processos: aponta para envs mamba existentes ──────────────
// MAMBA_ROOT_PREFIX = raiz fixa do mamba (não muda ao ativar envs)
// CONDA_PREFIX muda ao ativar cada env — não usar aqui
process {

    withName: 'FASTQC.*' {
        cpus     = 4
        memory   = '8 GB'
        maxForks = 6
        conda    = "${env('MAMBA_ROOT_PREFIX')}/envs/rnaseq-tools"
    }
    withName: 'MULTIQC.*' {
        cpus   = 2
        memory = '8 GB'
        conda  = "${env('MAMBA_ROOT_PREFIX')}/envs/rnaseq-tools"
    }
    withName: 'FASTP' {
        cpus     = 8
        memory   = '16 GB'
        maxForks = 4
        conda    = "${env('MAMBA_ROOT_PREFIX')}/envs/rnaseq-tools"
    }
    withName: 'GFFREAD' {
        cpus   = 2
        memory = '8 GB'
        conda  = "${env('MAMBA_ROOT_PREFIX')}/envs/rnaseq-tools"
    }
    withName: 'HISAT2_BUILD' {
        cpus   = 16
        memory = '64 GB'
        time   = '6 h'
        conda  = "${env('MAMBA_ROOT_PREFIX')}/envs/rnaseq-tools"
    }
    withName: 'HISAT2_ALIGN' {
        cpus     = 8
        memory   = '32 GB'
        maxForks = 4
        conda    = "${env('MAMBA_ROOT_PREFIX')}/envs/rnaseq-tools"
    }
    withName: 'SAMTOOLS.*' {
        cpus     = 8
        memory   = '16 GB'
        maxForks = 4
        conda    = "${env('MAMBA_ROOT_PREFIX')}/envs/rnaseq-tools"
    }
    withName: 'INFER_STRANDEDNESS' {
        cpus   = 2
        memory = '4 GB'
        conda  = "${env('MAMBA_ROOT_PREFIX')}/envs/rnaseq-tools"
    }
    withName: 'FEATURECOUNTS' {
        cpus   = 16
        memory = '32 GB'
        conda  = "${env('MAMBA_ROOT_PREFIX')}/envs/rnaseq-tools"
    }
    withName: 'RMATS' {
        cpus   = 16
        memory = '64 GB'
        time   = '24 h'
        conda  = "${env('MAMBA_ROOT_PREFIX')}/envs/rnaseq-tools"
    }
    withName: 'PARSE_COUNTS' {
        cpus   = 2
        memory = '8 GB'
        conda  = "${env('MAMBA_ROOT_PREFIX')}/envs/rnaseq-tools"
    }
    withName: 'PARSE_RMATS' {
        cpus   = 2
        memory = '8 GB'
        conda  = "${env('MAMBA_ROOT_PREFIX')}/envs/rnaseq-tools"
    }
    withName: 'DESEQ2' {
        cpus   = 8
        memory = '32 GB'
        conda  = "${env('MAMBA_ROOT_PREFIX')}/envs/r-analysis"
    }
    withName: 'ENRICHMENT' {
        cpus   = 8
        memory = '32 GB'
        conda  = "${env('MAMBA_ROOT_PREFIX')}/envs/r-analysis"
    }
    withName: 'WGCNA' {
        cpus   = 16
        memory = '64 GB'
        conda  = "${env('MAMBA_ROOT_PREFIX')}/envs/r-analysis"
    }
    withName: 'INTEGRATION' {
        cpus   = 4
        memory = '16 GB'
        conda  = "${env('MAMBA_ROOT_PREFIX')}/envs/r-analysis"
    }
    withName: 'QUARTO_REPORT' {
        cpus   = 4
        memory = '16 GB'
        conda  = "${env('MAMBA_ROOT_PREFIX')}/envs/r-analysis"
    }
}

// ── Relatórios Nextflow ───────────────────────────────────────
report {
    enabled   = true
    file      = "${params.outdir}/nextflow_report.html"
    overwrite = true
}

trace {
    enabled   = true
    file      = "${params.outdir}/nextflow_trace.txt"
    overwrite = true
    fields    = 'task_id,name,status,exit,realtime,%cpu,peak_rss,peak_vmem'
}

timeline {
    enabled   = true
    file      = "${params.outdir}/nextflow_timeline.html"
    overwrite = true
}

dag {
    enabled   = true
    file      = "${params.outdir}/nextflow_dag.html"
    overwrite = true
}

// ── Manifest ─────────────────────────────────────────────────
manifest {
    name            = 'soja-rnaseq'
    author          = 'Eulalio Santos'
    description     = 'Pipeline completo de RNA-Seq para Glycine max'
    version         = '1.0.0'
    nextflowVersion = '>=24.04'
}
