// ============================================================
// RNASeq Soja – Nextflow Configuration
// ============================================================

nextflow.enable.dsl = 2

// Default parameters (overridden by params.yaml or CLI)
params {
    samplesheet     = "samplesheet.csv"
    genome_fasta    = null
    genome_gff3     = null
    genome_gtf      = null           // se já tiver GTF, usa direto
    genome_index    = null           // se já tiver índice HISAT2, usa direto
    outdir          = "results"
    contrast        = "treatment_vs_control"
    control_group   = "control"
    treatment_group = "treatment"

    // Critérios DESeq2
    padj_cutoff     = 0.05
    lfc_cutoff      = 1.0

    // featureCounts
    strandedness    = 0              // 0=unstranded, 1=forward, 2=reverse (-1=auto)
    feature_type    = "exon"
    gene_attr       = "gene_id"

    // rMATS
    read_length     = 150
    rmats_type      = "paired"       // paired ou single

    // HISAT2
    hisat2_threads  = 16
    hisat2_max_intron = 500000

    // fastp
    min_length      = 36
    quality         = 20

    // Organism KEGG
    kegg_organism   = "gma"

    // Relatório
    report_title    = "RNASeq Insight – Glycine max"
    report_author   = "Eulalio Santos"
}

// ── Perfis de execução ────────────────────────────────────────
profiles {

    local {
        process {
            executor = 'local'
            cpus     = 16
            memory   = '64 GB'
            time     = '12 h'
        }
        conda {
            enabled    = true
            useMamba   = true
            cacheDir   = "${HOME}/.conda/envs"
        }
    }

    slurm {
        process {
            executor       = 'slurm'
            queue          = 'normal'
            cpus           = 16
            memory         = '64 GB'
            time           = '24 h'
            errorStrategy  = 'retry'
            maxRetries     = 2
            clusterOptions = '--partition=normal'
        }
        conda {
            enabled    = true
            useMamba   = true
            cacheDir   = "${HOME}/.conda/envs"
        }
    }

    test {
        params {
            samplesheet     = "data/example/samplesheet_test.csv"
            genome_fasta    = "data/example/genome_test.fa"
            genome_gff3     = "data/example/annotation_test.gff3"
            outdir          = "results_test"
            read_length     = 75
        }
        process {
            executor = 'local'
            cpus     = 2
            memory   = '8 GB'
            time     = '2 h'
        }
        conda {
            enabled  = true
            useMamba = true
        }
    }
}

// ── Configuração de processos por ferramenta (32 CPUs / 188 GB) ──
process {
    withName: 'FASTQC.*' {
        cpus     = 4
        memory   = '8 GB'
        maxForks = 6          // até 6 amostras em paralelo
        conda    = "${projectDir}/envs/rnaseq-tools.yml"
    }
    withName: 'MULTIQC.*' {
        cpus   = 2
        memory = '8 GB'
        conda  = "${projectDir}/envs/rnaseq-tools.yml"
    }
    withName: 'FASTP' {
        cpus     = 8
        memory   = '16 GB'
        maxForks = 4          // 4 × 8 = 32 CPUs em paralelo
        conda    = "${projectDir}/envs/rnaseq-tools.yml"
    }
    withName: 'HISAT2_BUILD' {
        cpus   = 16
        memory = '64 GB'
        time   = '6 h'
        conda  = "${projectDir}/envs/rnaseq-tools.yml"
    }
    withName: 'HISAT2_ALIGN' {
        cpus     = 8
        memory   = '32 GB'
        maxForks = 4          // 4 alinhamentos simultâneos
        conda    = "${projectDir}/envs/rnaseq-tools.yml"
    }
    withName: 'SAMTOOLS.*' {
        cpus     = 8
        memory   = '16 GB'
        maxForks = 4
        conda    = "${projectDir}/envs/rnaseq-tools.yml"
    }
    withName: 'GFFREAD' {
        cpus   = 2
        memory = '8 GB'
        conda  = "${projectDir}/envs/rnaseq-tools.yml"
    }
    withName: 'INFER_STRANDEDNESS' {
        cpus   = 2
        memory = '4 GB'
        conda  = "${projectDir}/envs/rnaseq-tools.yml"
    }
    withName: 'FEATURECOUNTS' {
        cpus   = 16
        memory = '32 GB'
        conda  = "${projectDir}/envs/rnaseq-tools.yml"
    }
    withName: 'RMATS' {
        cpus   = 16
        memory = '64 GB'
        time   = '24 h'
        conda  = "${projectDir}/envs/rnaseq-tools.yml"
    }
    withName: 'DESEQ2' {
        cpus   = 8
        memory = '32 GB'
        conda  = "${projectDir}/envs/r-analysis.yml"
    }
    withName: 'ENRICHMENT' {
        cpus   = 8
        memory = '32 GB'
        conda  = "${projectDir}/envs/r-analysis.yml"
    }
    withName: 'WGCNA' {
        cpus   = 16
        memory = '64 GB'
        conda  = "${projectDir}/envs/r-analysis.yml"
    }
    withName: 'INTEGRATION' {
        cpus   = 4
        memory = '16 GB'
        conda  = "${projectDir}/envs/r-analysis.yml"
    }
    withName: 'QUARTO_REPORT' {
        cpus   = 4
        memory = '16 GB'
        conda  = "${projectDir}/envs/r-analysis.yml"
    }
}

// ── Relatórios Nextflow ───────────────────────────────────────
report {
    enabled  = true
    file     = "${params.outdir}/nextflow_report.html"
    overwrite = true
}

trace {
    enabled   = true
    file      = "${params.outdir}/nextflow_trace.txt"
    overwrite = true
    fields    = 'task_id,name,status,exit,realtime,%cpu,peak_rss,peak_vmem'
}

timeline {
    enabled  = true
    file     = "${params.outdir}/nextflow_timeline.html"
    overwrite = true
}

dag {
    enabled  = true
    file     = "${params.outdir}/nextflow_dag.html"
    overwrite = true
}

// ── Manifest ─────────────────────────────────────────────────
manifest {
    name            = 'soja-rnaseq'
    author          = 'Eulalio Santos'
    description     = 'Pipeline completo de RNA-Seq para Glycine max'
    version         = '1.0.0'
    nextflowVersion = '>=24.04'
}
